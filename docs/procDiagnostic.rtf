\f1\b0\fs24 \cf0 Evite criar e destruir muitos 
\f2\fs26 SKSpriteNode
\f1\fs24  durante gameplay.\
Use pools:\
\pard\pardeftab720\partightenfactor0

\f2\fs26 \cf0 final class SpritePool \{\
    private var pool: [SKSpriteNode] = []\
\
    func get(texture: SKTexture) -> SKSpriteNode \{\
        if let node = pool.popLast() \{\
            node.texture = texture\
            node.isHidden = false\
            return node\
        \}\
\
        return SKSpriteNode(texture: texture)\
    \}\
\
    func recycle(_ node: SKSpriteNode) \{\
        node.removeFromParent()\
        node.removeAllActions()\
        node.isHidden = true\
        pool.append(node)\
    \}\
\}\
\pard\pardeftab720\sa240\partightenfactor0


{
  "name": "mermaid-web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "extract-assets": "node scripts/extract-assets.mjs",
    "predev": "npm run extract-assets",
    "dev": "vite --host 127.0.0.1",
    "prebuild": "npm run extract-assets",
    "build": "tsc -b && vite build",
    "preview": "vite preview --host 127.0.0.1",
    "test": "vitest run",
    "test:watch": "vitest",
    "pretest:e2e": "npm run build",
    "test:e2e": "playwright test",
    "pretest:e2e:update": "npm run build",
    "test:e2e:update": "playwright test --update-snapshots"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^5.0.0",
    "gsap": "^3.15.0",
    "pixi.js": "^8.18.1",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "vite": "^7.0.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.52.0",
    "@types/node": "^22.15.30",
    "@types/react": "^19.1.6",
    "@types/react-dom": "^19.1.6",
    "pngjs": "^7.0.0",
    "typescript": "^5.8.3",
    "vitest": "^4.1.8"
  }
}
